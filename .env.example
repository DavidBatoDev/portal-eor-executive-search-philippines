# Copy this file to .env.local and fill in your values.

# OpenAI API key — used by the chat route handler (app/api/chat).
OPENAI_API_KEY=

# Chat model (optional; defaults to gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Public site origin (no trailing slash). Used for canonical URLs, Open Graph
# tags, the sitemap, and robots.txt. MUST be set to the real production domain
# before deploying — defaults to http://localhost:3000 in development.
NEXT_PUBLIC_SITE_URL=https://www.your-domain.com

# Zoho Mail integration (Contact + Book a Meeting forms) — sends an email via
# the Zoho Mail REST API for every submission. OAuth Self Client credentials;
# generate via api-console.zoho.com (Self Client, scope ZohoMail.messages.CREATE)
# — never use the account password.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Zoho data center suffix for your account (com, in, eu, com.cn, jp, au).
ZOHO_DC=com

# Zoho Mail account ID that owns the OAuth grant (from GET
# https://mail.zoho.com/api/accounts using an access token during setup).
ZOHO_MAIL_ACCOUNT_ID=

# Sender address (must be a verified address on the above account) and the
# inbox that receives both Contact and Meeting Request submissions.
ZOHO_FROM_ADDRESS=portal@helprofgrp.com
ZOHO_TO_ADDRESS=portal@helprofgrp.com
